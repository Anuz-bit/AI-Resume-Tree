{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "TreeNode",
    "type": "object",
    "properties": {
        "node_id": {
            "type": "string"
        },
        "type": {
            "type": "string",
            "enum": [
                "root",
                "section",
                "experience",
                "project",
                "education",
                "skills"
            ]
        },
        "title": {
            "type": "string"
        },
        "level": {
            "type": "integer",
            "enum": [
                0,
                1,
                2
            ]
        },
        "summary": {
            "type": "string"
        },
        "metadata": {
            "type": "object",
            "properties": {
                "career_stage": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "junior",
                        "mid",
                        "senior",
                        "lead",
                        null
                    ]
                },
                "tech_stack": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "duration_months": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "recency": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "recent",
                        "moderate",
                        "old",
                        null
                    ]
                },
                "complexity": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "low",
                        "medium",
                        "high",
                        null
                    ]
                },
                "has_outcome": {
                    "type": "boolean"
                },
                "responsibility_level": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "individual",
                        "team",
                        "org",
                        null
                    ]
                }
            },
            "required": [
                "career_stage",
                "tech_stack",
                "duration_months",
                "recency",
                "complexity",
                "has_outcome",
                "responsibility_level"
            ]
        },
        "children": {
            "type": "array",
            "items": {
                "$ref": "#"
            }
        }
    },
    "required": [
        "node_id",
        "type",
        "title",
        "level",
        "summary",
        "metadata",
        "children"
    ]
}